import { useState, useCallback, useEffect } from 'react';
import { useNavigate, useSearchParams } from 'react-router-dom';
import {
    Box,
    Card,
    CardContent,
    Typography,
    TextField,
    InputAdornment,
    Table,
    TableBody,
    TableCell,
    TableContainer,
    TableHead,
    TableRow,
    TablePagination,
    Chip,
    IconButton,
    Select,
    MenuItem,
    FormControl,
    InputLabel,
    Skeleton,
    Tooltip,
    useTheme,
    useMediaQuery,
    Grid,
    Divider,
    LinearProgress,
    ToggleButtonGroup,
    ToggleButton,
    alpha,
    Button,
    Fade,
    Zoom,
    CardActionArea,
} from '@mui/material';
import {
    Search as SearchIcon,
    Visibility as ViewIcon,
    PlayArrow as RunningIcon,
    Stop as StoppedIcon,
    Shield as ShieldIcon,
    ShieldOutlined as UnprotectedIcon,
    GridView as GridViewIcon,
    TableRows as TableViewIcon,
    BarChart as ChartIcon,
    FilterList as FilterIcon,
    Computer as ComputerIcon,
    Memory as MemoryIcon,
    Storage as StorageIcon,
    Speed as SpeedIcon,
    CheckCircle as CheckCircleIcon,
    Cancel as CancelIcon,
    Warning as WarningIcon,
    Refresh as RefreshIcon,
} from '@mui/icons-material';
import { useQuery } from '@tanstack/react-query';
import { vmsApi, dashboardApi } from '../services/api';
import type { VM, GroupSummary } from '../types';
import { useThemeStore } from '../stores/themeStore';

export default function VMListPage() {
    const navigate = useNavigate();
    const [searchParams, setSearchParams] = useSearchParams();
    const theme = useTheme();
    const isMobile = useMediaQuery(theme.breakpoints.down('md'));
    const { mode } = useThemeStore();

    // View mode state (grid, table, chart)
    const [viewMode, setViewMode] = useState<'grid' | 'table' | 'chart'>('grid');

    // Initialize state from URL params
    const [search, setSearch] = useState(searchParams.get('search') || '');
    const [status, setStatus] = useState(searchParams.get('status') || '');
    const [groupId, setGroupId] = useState(searchParams.get('group') || '');
    const [page, setPage] = useState(parseInt(searchParams.get('page') || '0', 10));
    const [pageSize, setPageSize] = useState(parseInt(searchParams.get('size') || '20', 10));

    // Update URL when filters change
    useEffect(() => {
        const params = new URLSearchParams();
        if (search) params.set('search', search);
        if (status) params.set('status', status);
        if (groupId) params.set('group', groupId);
        if (page > 0) params.set('page', page.toString());
        if (pageSize !== 20) params.set('size', pageSize.toString());
        setSearchParams(params, { replace: true });
    }, [search, status, groupId, page, pageSize, setSearchParams]);

    // Debounced search
    const debouncedSearch = useCallback((value: string) => {
        const timeout = setTimeout(() => {
            setSearch(value);
            setPage(0);
        }, 300);
        return () => clearTimeout(timeout);
    }, []);

    // Fetch groups for filter
    const { data: groups } = useQuery<{ data: GroupSummary[] }>({
        queryKey: ['groups'],
        queryFn: () => dashboardApi.getGroups(),
    });

    // Fetch VMs
    const { data: vmsData, isLoading } = useQuery({
        queryKey: ['vms', page, pageSize, search, status, groupId],
        queryFn: () =>
            vmsApi.getList({
                page: page + 1, // API is 1-indexed
                page_size: pageSize,
                search: search || undefined,
                status: status || undefined,
                group_id: groupId || undefined,
            }),
    });

    const vms: VM[] = vmsData?.data?.items || [];
    const total = vmsData?.data?.total || 0;

    const handlePageChange = (_: unknown, newPage: number) => {
        setPage(newPage);
    };

    const handleRowsPerPageChange = (event: React.ChangeEvent<HTMLInputElement>) => {
        setPageSize(parseInt(event.target.value, 10));
        setPage(0);
    };

    const getStatusChip = (powerState: string | null) => {
        if (powerState === 'on') {
            return (
                <Chip
                    icon={<RunningIcon sx={{ fontSize: 16 }} />}
                    label="ทำงาน"
                    size="small"
                    sx={{
                        bgcolor: 'rgba(34, 197, 94, 0.15)',
                        color: 'success.main',
                        fontWeight: 500,
                    }}
                />
            );
        }
        return (
            <Chip
                icon={<StoppedIcon sx={{ fontSize: 16 }} />}
                label="หยุด"
                size="small"
                sx={{
                    bgcolor: 'rgba(239, 68, 68, 0.15)',
                    color: 'error.main',
                    fontWeight: 500,
                }}
            />
        );
    };

    const formatUsage = (value: number | null) => {
        if (value === null || value === undefined) return '-';
        return `${(value * 100).toFixed(1)}%`;
    };

    const formatStorage = (mb: number | null) => {
        if (!mb) return '-';
        if (mb >= 1024 * 1024) return `${(mb / 1024 / 1024).toFixed(1)} TB`;
        if (mb >= 1024) return `${(mb / 1024).toFixed(1)} GB`;
        return `${mb.toFixed(0)} MB`;
    };

    // Mobile Card Component
    const MobileVMCard = ({ vm }: { vm: VM }) => (
        <Card 
            sx={{ 
                mb: 2, 
                cursor: 'pointer',
                '&:hover': { boxShadow: 4 },
                transition: 'box-shadow 0.2s'
            }}
            onClick={() => navigate(`/vms/${vm.vm_uuid}`)}
        >
            <CardContent>
                <Box sx={{ display: 'flex', justifyContent: 'space-between', alignItems: 'start', mb: 2 }}>
                    <Box sx={{ flex: 1 }}>
                        <Typography variant="h6" fontWeight={600} sx={{ mb: 0.5 }}>
                            {vm.name}
                        </Typography>
                        <Typography variant="caption" color="text.secondary">
                            {vm.os_kernel || vm.os_type || 'Unknown OS'}
                        </Typography>
                    </Box>
                    <Box sx={{ ml: 1 }}>
                        {getStatusChip(vm.power_state)}
                    </Box>
                </Box>

                <Divider sx={{ my: 1.5 }} />

                <Grid container spacing={2}>
                    <Grid item xs={6}>
                        <Typography variant="caption" color="text.secondary">IP Address</Typography>
                        <Typography variant="body2" fontWeight={500} sx={{ fontFamily: 'monospace', fontSize: '0.85rem' }}>
                            {vm.ip_address ? vm.ip_address.split(',')[0].trim() : '-'}
                        </Typography>
                    </Grid>
                    <Grid item xs={6}>
                        <Typography variant="caption" color="text.secondary">กลุ่ม</Typography>
                        <Typography variant="body2" fontWeight={500}>
                            {vm.group_name || '-'}
                        </Typography>
                    </Grid>
                    <Grid item xs={4}>
                        <Typography variant="caption" color="text.secondary">CPU</Typography>
                        <Typography variant="body2" fontWeight={600} color="primary.main">
                            {formatUsage(vm.cpu_usage)}
                        </Typography>
                    </Grid>
                    <Grid item xs={4}>
                        <Typography variant="caption" color="text.secondary">Memory</Typography>
                        <Typography variant="body2" fontWeight={600} color="secondary.main">
                            {formatUsage(vm.memory_usage)}
                        </Typography>
                    </Grid>
                    <Grid item xs={4}>
                        <Typography variant="caption" color="text.secondary">Disk</Typography>
                        <Typography variant="body2" fontWeight={600}>
                            {formatStorage(vm.storage_total_mb)}
                        </Typography>
                    </Grid>
                </Grid>

                <Box sx={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', mt: 2 }}>
                    <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                        <Tooltip title={
                            vm.in_protection
                                ? `มีการปกป้อง: ${vm.protection_name || 'N/A'}`
                                : vm.backup_file_count && vm.backup_file_count > 0
                                    ? `Backup Manual (${vm.backup_file_count} ไฟล์)`
                                    : 'ไม่มีการปกป้อง'
                        }>
                            {vm.in_protection ? (
                                <ShieldIcon color="success" fontSize="small" />
                            ) : vm.backup_file_count && vm.backup_file_count > 0 ? (
                                <ShieldIcon color="warning" fontSize="small" sx={{ opacity: 0.6 }} />
                            ) : (
                                <UnprotectedIcon color="disabled" fontSize="small" />
                            )}
                        </Tooltip>
                        <Typography variant="caption" color="text.secondary">
                            {vm.host_name || '-'}
                        </Typography>
                    </Box>
                    <IconButton size="small" color="primary">
                        <ViewIcon fontSize="small" />
                    </IconButton>
                </Box>
            </CardContent>
        </Card>
    );

    return (
        <Box className="animate-fade-in">
            {/* Page Header */}
            <Box sx={{ mb: 4 }}>
                <Typography 
                    variant="h4" 
                    sx={{ 
                        fontWeight: 800,
                        background: 'linear-gradient(135deg, #0ea5e9 0%, #22c55e 100%)',
                        backgroundClip: 'text',
                        WebkitBackgroundClip: 'text',
                        WebkitTextFillColor: 'transparent',
                    }}
                    gutterBottom
                >
                    💻 Virtual Machines
                </Typography>
                <Typography variant="body1" color="text.secondary">
                    จัดการและติดตามเครื่องเสมือนทั้งหมด
                </Typography>
            </Box>

            {/* Filters */}
            <Card sx={{ mb: 3 }} className="card-hover">
                <CardContent sx={{ p: 2 }}>
                    <Box sx={{ display: 'flex', gap: 2, flexWrap: 'wrap' }}>
                        <TextField
                            placeholder="ค้นหา VM..."
                            size="small"
                            defaultValue={search}
                            onChange={(e) => debouncedSearch(e.target.value)}
                            sx={{ minWidth: 250, flex: 1 }}
                            InputProps={{
                                startAdornment: (
                                    <InputAdornment position="start">
                                        <SearchIcon color="action" />
                                    </InputAdornment>
                                ),
                            }}
                        />
                        <FormControl size="small" sx={{ minWidth: 140 }}>
                            <InputLabel>สถานะ</InputLabel>
                            <Select
                                value={status}
                                label="สถานะ"
                                onChange={(e) => {
                                    setStatus(e.target.value);
                                    setPage(0);
                                }}
                            >
                                <MenuItem value="">ทั้งหมด</MenuItem>
                                <MenuItem value="on">ทำงาน</MenuItem>
                                <MenuItem value="off">หยุด</MenuItem>
                            </Select>
                        </FormControl>
                        <FormControl size="small" sx={{ minWidth: 180 }}>
                            <InputLabel>กลุ่ม</InputLabel>
                            <Select
                                value={groupId}
                                label="กลุ่ม"
                                onChange={(e) => {
                                    setGroupId(e.target.value);
                                    setPage(0);
                                }}
                            >
                                <MenuItem value="">ทุกกลุ่ม</MenuItem>
                                {groups?.data?.map((g) => (
                                    <MenuItem key={g.group_id} value={g.group_id}>
                                        {g.group_name}
                                    </MenuItem>
                                ))}
                            </Select>
                        </FormControl>
                    </Box>
                </CardContent>
            </Card>

            {/* Mobile View: Cards */}
            {isMobile ? (
                <Box>
                    {isLoading ? (
                        [...Array(5)].map((_, i) => (
                            <Card key={i} sx={{ mb: 2 }}>
                                <CardContent>
                                    <Skeleton variant="text" width="60%" height={32} />
                                    <Skeleton variant="text" width="40%" />
                                    <Skeleton variant="rectangular" height={80} sx={{ mt: 2 }} />
                                </CardContent>
                            </Card>
                        ))
                    ) : vms.length === 0 ? (
                        <Card>
                            <CardContent sx={{ py: 8, textAlign: 'center' }}>
                                <Typography color="text.secondary">
                                    ไม่พบเครื่องเสมือน
                                </Typography>
                            </CardContent>
                        </Card>
                    ) : (
                        vms.map((vm) => <MobileVMCard key={vm.vm_uuid} vm={vm} />)
                    )}
                    <Card>
                        <TablePagination
                            component="div"
                            count={total}
                            page={page}
                            onPageChange={handlePageChange}
                            rowsPerPage={pageSize}
                            onRowsPerPageChange={handleRowsPerPageChange}
                            rowsPerPageOptions={[10, 20, 50]}
                        />
                    </Card>
                </Box>
            ) : (
                /* Desktop View: Table */
                <Card>
                    <TableContainer>
                        <Table>
                            <TableHead>
                                <TableRow>
                                    <TableCell sx={{ fontWeight: 600 }}>ชื่อ</TableCell>
                                    <TableCell sx={{ fontWeight: 600 }}>สถานะ</TableCell>
                                    <TableCell sx={{ fontWeight: 600 }}>IP Address</TableCell>
                                    <TableCell sx={{ fontWeight: 600 }}>กลุ่ม</TableCell>
                                    <TableCell sx={{ fontWeight: 600 }}>Host</TableCell>
                                    <TableCell sx={{ fontWeight: 600 }} align="right">CPU</TableCell>
                                    <TableCell sx={{ fontWeight: 600 }} align="right">หน่วยความจำ</TableCell>
                                    <TableCell sx={{ fontWeight: 600 }} align="right">พื้นที่ดิสก์</TableCell>
                                    <TableCell sx={{ fontWeight: 600 }} align="center">การปกป้อง</TableCell>
                                    <TableCell sx={{ fontWeight: 600 }} align="center">ดูข้อมูล</TableCell>
                                </TableRow>
                            </TableHead>
                            <TableBody>
                                {isLoading ? (
                                    [...Array(10)].map((_, i) => (
                                        <TableRow key={i}>
                                            {[...Array(10)].map((_, j) => (
                                                <TableCell key={j}>
                                                    <Skeleton />
                                                </TableCell>
                                            ))}
                                        </TableRow>
                                    ))
                                ) : vms.length === 0 ? (
                                    <TableRow>
                                        <TableCell colSpan={10} align="center" sx={{ py: 6 }}>
                                            <Typography color="text.secondary">
                                                ไม่พบเครื่องเสมือน
                                            </Typography>
                                        </TableCell>
                                    </TableRow>
                                ) : (
                                    vms.map((vm) => (
                                        <TableRow
                                            key={vm.vm_uuid}
                                            hover
                                            sx={{ cursor: 'pointer' }}
                                            onClick={() => navigate(`/vms/${vm.vm_uuid}`)}
                                        >
                                            <TableCell>
                                                <Box>
                                                    <Typography variant="body2" fontWeight={500}>
                                                        {vm.name}
                                                    </Typography>
                                                    <Typography variant="caption" color="text.secondary">
                                                        {vm.os_kernel || vm.os_type || 'Unknown OS'}
                                                    </Typography>
                                                </Box>
                                            </TableCell>
                                            <TableCell>{getStatusChip(vm.power_state)}</TableCell>
                                            <TableCell>
                                                {vm.ip_address ? (
                                                    <Box>
                                                        {vm.ip_address.split(',').map((ip, i) => (
                                                            <Typography key={i} variant="body2" sx={{ fontFamily: 'monospace', fontSize: '0.8rem', whiteSpace: 'nowrap' }}>
                                                                {ip.trim()}
                                                            </Typography>
                                                        ))}
                                                    </Box>
                                                ) : (
                                                    <Typography variant="body2" sx={{ fontFamily: 'monospace', fontSize: '0.8rem' }}>-</Typography>
                                                )}
                                            </TableCell>
                                            <TableCell>
                                                <Typography variant="body2" color="text.secondary">
                                                    {vm.group_name || '-'}
                                                </Typography>
                                            </TableCell>
                                            <TableCell>
                                                <Typography variant="body2" color="text.secondary">
                                                    {vm.host_name || '-'}
                                                </Typography>
                                            </TableCell>
                                            <TableCell align="right">
                                                <Typography variant="body2">
                                                    {formatUsage(vm.cpu_usage)}
                                                </Typography>
                                            </TableCell>
                                            <TableCell align="right">
                                                <Typography variant="body2">
                                                    {formatUsage(vm.memory_usage)}
                                                </Typography>
                                            </TableCell>
                                            <TableCell align="right">
                                                <Typography variant="body2">
                                                    {formatStorage(vm.storage_total_mb)}
                                                </Typography>
                                            </TableCell>
                                            <TableCell align="center">
                                                <Tooltip title={
                                                    vm.in_protection
                                                        ? `มีการปกป้อง: ${vm.protection_name || 'N/A'}`
                                                        : vm.backup_file_count && vm.backup_file_count > 0
                                                            ? `Backup Manual (${vm.backup_file_count} ไฟล์)`
                                                            : 'ไม่มีการปกป้อง'
                                                }>
                                                    {vm.in_protection ? (
                                                        <ShieldIcon color="success" fontSize="small" />
                                                    ) : vm.backup_file_count && vm.backup_file_count > 0 ? (
                                                        <ShieldIcon color="warning" fontSize="small" sx={{ opacity: 0.6 }} />
                                                    ) : (
                                                        <UnprotectedIcon color="disabled" fontSize="small" />
                                                    )}
                                                </Tooltip>
                                            </TableCell>
                                            <TableCell align="center">
                                                <Tooltip title="ดูรายละเอียด">
                                                    <IconButton
                                                        size="small"
                                                        onClick={(e) => {
                                                            e.stopPropagation();
                                                            navigate(`/vms/${vm.vm_uuid}`);
                                                        }}
                                                    >
                                                        <ViewIcon fontSize="small" />
                                                    </IconButton>
                                                </Tooltip>
                                            </TableCell>
                                        </TableRow>
                                    ))
                                )}
                            </TableBody>
                        </Table>
                    </TableContainer>
                    <TablePagination
                        component="div"
                        count={total}
                        page={page}
                        onPageChange={handlePageChange}
                        rowsPerPage={pageSize}
                        onRowsPerPageChange={handleRowsPerPageChange}
                        rowsPerPageOptions={[10, 20, 50, 100]}
                    />
                </Card>
            )}
        </Box>
    );
}
