# ==========================================
# Sangfor SCP VMStat - Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to Git!

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
pgSQL_HOST=localhost
pgSQL_HOST_PORT=5432
pgSQL_DBNAME=sangfor_scp
pgSQL_USERNAME=postgres
pgSQL_PASSWORD=your_database_password_here

# Alternative database variable names (optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sangfor_scp
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# ==========================================
# Sangfor SCP API Configuration
# ==========================================
SCP_IP=your_sangfor_scp_ip_here
SCP_USERNAME=your_sangfor_admin_username
SCP_PASSWORD=your_sangfor_admin_password
SCP_TOKEN=your_sangfor_api_token_here

# ==========================================
# Application Security
# ==========================================
# Generate a secure random key for production:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-frontend-domain.com,https://10.251.150.222:3345

# ==========================================
# Sync Settings
# ==========================================
SYNC_INTERVAL_MINUTES=5
SYNC_AUTO_START=True

# ==========================================
# Application Settings
# ==========================================
APP_NAME=VMStat API
APP_VERSION=1.0.0
DEBUG=False

# ==========================================
# Testing (Optional)
# ==========================================
TEST_ADMIN_PASSWORD=admin123
TEST_USER=viewer_user
TEST_PASS=Viewer@2026!
